#include <stdio.h>
#include <stdlib.h>


int main()
{
    int mathematics, science, english;
    int totalMarks;
    float averageMarks;

    printf("Enter the marks of Mathematics: ");
    scanf("%d", &mathematics);

    printf("Enter the marks of Science: ");
    scanf("%d", &science);

    printf("Enter the marks of English: ");
    scanf("%d", &english);

    totalMarks = mathematics + science + english;
    averageMarks = totalMarks / 3.0;

    printf("Total: %d\n", totalMarks);
    printf("Average: %.2f\n", averageMarks);

    if (averageMarks >= 80 && averageMarks <= 100)
    {
        printf("Grade: A\n");
    }
    else if (averageMarks >= 70 && averageMarks < 80)
    {
        printf("Grade: B\n");
    }
    else if (averageMarks >= 60 && averageMarks < 70)
    {
        printf("Grade: C\n");
    }
    else if (averageMarks >= 50 && averageMarks < 60)
    {
        printf("Grade: D\n");
    }
    else
    {
        printf("Grade: F\n");
    }

    if (mathematics >= 40 && science >= 40 && english >= 40)
    {
        printf("Result: Pass\n");
    }
    else
    {
        printf("Result: Fail\n");
    }

    return 0;
}



